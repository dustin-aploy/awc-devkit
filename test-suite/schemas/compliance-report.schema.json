{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arp.dev/schemas/compliance-report.schema.json",
  "title": "AI Work Contract (AWC) Compliance Report",
  "description": "Schema for recording validation or certification-oriented findings against an AWC declaration, formerly an ARP declaration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "report_id",
    "generated_at",
    "subject",
    "protocol_version",
    "profile",
    "summary",
    "checks"
  ],
  "properties": {
    "kind": { "const": "AWCComplianceReport" },
    "report_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "declaration_digest"],
      "properties": {
        "agent_id": { "type": "string", "minLength": 1 },
        "declaration_digest": { "type": "string", "pattern": "^[A-Fa-f0-9]{32,128}$" },
        "artifact_uri": { "type": "string", "format": "uri" }
      }
    },
    "protocol_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "issuer": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "passed", "failed"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "conditional-pass", "fail"] },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "pillar", "description", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "pillar": {
            "type": "string",
            "enum": [
              "identity",
              "scope",
              "authority",
              "escalation",
              "audit",
              "memory",
              "budget",
              "performance"
            ]
          },
          "description": { "type": "string", "minLength": 3 },
          "status": { "type": "string", "enum": ["pass", "warning", "fail", "not-applicable"] },
          "evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "remediation": { "type": "string", "minLength": 3 }
        }
      }
    },
    "attestations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "timestamp"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "timestamp": { "type": "string", "format": "date-time" },
          "statement": { "type": "string", "minLength": 3 }
        }
      }
    }
  }
}
